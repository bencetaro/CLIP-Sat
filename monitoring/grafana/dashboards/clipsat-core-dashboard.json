{
  "title": "CLIPSAT Core Monitoring",
  "uid": "clipsat-core",
  "schemaVersion": 42,
  "version": 2,
  "refresh": "10s",
  "timezone": "browser",
  "tags": ["clipsat", "core", "inference"],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(inference_requests_total, model)",
        "multi": true,
        "includeAll": true,
        "refresh": 1
      },
      {
        "name": "endpoint",
        "label": "Endpoint",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(inference_requests_total, endpoint)",
        "multi": true,
        "includeAll": true,
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "System Resources",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CPU Utilization Over Time",
      "gridPos": {"h": 8, "w": 18, "x": 0, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "{{instance}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "percent"}, "overrides": []}
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "CPU Utilization",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "{{instance}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "orange", "value": 70}, {"color": "red", "value": 90}]}}, "overrides": []}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Memory Utilization Over Time",
      "gridPos": {"h": 8, "w": 18, "x": 0, "y": 9},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))", "legendFormat": "{{instance}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "percent"}, "overrides": []}
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "Memory Utilization",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 9},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))", "legendFormat": "{{instance}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "orange", "value": 75}, {"color": "red", "value": 90}]}}, "overrides": []}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Disk Utilization Over Time",
      "gridPos": {"h": 8, "w": 18, "x": 0, "y": 17},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "100 * (1 - (node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|overlay\"}))", "legendFormat": "{{instance}} {{mountpoint}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "percent"}, "overrides": []}
    },
    {
      "id": 7,
      "type": "gauge",
      "title": "Disk Utilization",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 17},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "max(100 * (1 - (node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|overlay\"})))", "legendFormat": "peak"}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "orange", "value": 75}, {"color": "red", "value": 90}]}}, "overrides": []}
    },

    {
      "id": 10,
      "type": "row",
      "title": "Inference Throughput & Errors",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 25},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Requests / sec by Endpoint",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 26},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(rate(inference_requests_total{endpoint=~\"$endpoint\"}[5m])) by (endpoint)", "legendFormat": "{{endpoint}}"}
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Requests / sec by Model",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 26},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(rate(inference_requests_total{model=~\"$model\"}[5m])) by (model)", "legendFormat": "{{model}}"}
      ]
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Error Rate (%)",
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 34},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "100 * sum(rate(inference_errors_total[5m])) / clamp_min(sum(rate(inference_requests_total[5m])), 1e-9)"}
      ],
      "fieldConfig": {"defaults": {"unit": "percent"}, "overrides": []}
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Invalid Payload Rate (/s)",
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 34},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(invalid_payload_total[5m]))"}]
    },
    {
      "id": 15,
      "type": "stat",
      "title": "In-flight Requests",
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 34},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(inference_inflight)"}]
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Prediction Errors by Stage",
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 34},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(prediction_errors_total[5m])) by (stage)", "legendFormat": "{{stage}}"}]
    },

    {
      "id": 20,
      "type": "row",
      "title": "Latency & Payload",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 39},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Inference Latency P50 / P95 / P99",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 40},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(inference_latency_seconds_bucket[5m])) by (le))", "legendFormat": "P50"},
        {"expr": "histogram_quantile(0.95, sum(rate(inference_latency_seconds_bucket[5m])) by (le))", "legendFormat": "P95"},
        {"expr": "histogram_quantile(0.99, sum(rate(inference_latency_seconds_bucket[5m])) by (le))", "legendFormat": "P99"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Preprocessing Latency P95",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 40},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(preprocessing_latency_seconds_bucket[5m])) by (le, model))", "legendFormat": "{{model}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Request Payload P95",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 48},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(inference_request_bytes_bucket[5m])) by (le, endpoint))", "legendFormat": "{{endpoint}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []}
    },
    {
      "id": 24,
      "type": "timeseries",
      "title": "Response Payload P95",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 48},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(inference_response_bytes_bucket[5m])) by (le, endpoint))", "legendFormat": "{{endpoint}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []}
    },

    {
      "id": 30,
      "type": "row",
      "title": "Prediction & LLM",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 56},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Predicted Class Count (1h Increase)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 57},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "topk(14, sum(increase(predicted_class_total[1h])) by (label))", "legendFormat": "{{label}}"}
      ]
    },
    {
      "id": 32,
      "type": "heatmap",
      "title": "Prediction Confidence Distribution",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 57},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(rate(prediction_value_bucket[5m])) by (le)"}
      ]
    },
    {
      "id": 33,
      "type": "timeseries",
      "title": "LLM Requests / sec",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 65},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(rate(llm_requests_total[5m])) by (endpoint, status)", "legendFormat": "{{endpoint}} {{status}}"}
      ]
    },
    {
      "id": 34,
      "type": "timeseries",
      "title": "LLM Latency P95",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 65},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(llm_latency_seconds_bucket[5m])) by (le, endpoint))", "legendFormat": "{{endpoint}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 35,
      "type": "stat",
      "title": "Loaded LLM Client Count",
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 73},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "llm_loaded"}]
    },
    {
      "id": 36,
      "type": "timeseries",
      "title": "UI Page Views",
      "gridPos": {"h": 5, "w": 18, "x": 6, "y": 73},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(page_views_total[5m])) by (endpoint)", "legendFormat": "{{endpoint}}"}]
    }
  ]
}
