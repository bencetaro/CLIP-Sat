{
  "title": "CLIPSAT Core Inference Monitoring",
  "uid": "clipsat-core",
  "schemaVersion": 42,
  "version": 1,
  "refresh": "10s",
  "timezone": "browser",
  "tags": ["clipsat", "inference"],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(inference_requests_total, model)",
        "multi": true,
        "includeAll": true,
        "refresh": 1
      },
      {
        "name": "endpoint",
        "label": "Endpoint",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(inference_requests_total, endpoint)",
        "multi": true,
        "includeAll": true,
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requests/sec",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(inference_requests_total[5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate %",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "(sum(rate(inference_errors_total[5m])) / sum(rate(inference_requests_total[5m]))) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Inflight Requests",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(inference_inflight)"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Invalid Payloads/sec",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(invalid_payload_total[5m]))"
        }
      ]
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Requests/sec by Endpoint",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(inference_requests_total{endpoint=~\"$endpoint\"}[5m])) by (endpoint)",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Requests/sec by Model",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(inference_requests_total{model=~\"$model\"}[5m])) by (model)",
          "legendFormat": "{{model}}"
        }
      ]
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Inference Latency P50/P95/P99",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(inference_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(inference_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(inference_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "Preprocessing Latency P95",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(preprocessing_latency_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "Prediction Errors by Stage",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "sum(rate(prediction_errors_total[5m])) by (stage)",
          "legendFormat": "{{stage}}"
        }
      ]
    },

    {
      "id": 10,
      "type": "barchart",
      "title": "Predicted Class Distribution",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "targets": [
        {
          "expr": "topk(10, sum(increase(predicted_class_total[1h])) by (label))",
          "legendFormat": "{{label}}"
        }
      ]
    },

    {
      "id": 11,
      "type": "heatmap",
      "title": "Prediction Confidence Distribution",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 30 },
      "targets": [
        {
          "expr": "sum(rate(prediction_value_bucket[5m])) by (le)"
        }
      ]
    },

    {
      "id": 12,
      "type": "timeseries",
      "title": "Request Payload Size P95",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(inference_request_bytes_bucket[5m])) by (le, endpoint))",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },

    {
      "id": 13,
      "type": "timeseries",
      "title": "Response Payload Size P95",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(inference_response_bytes_bucket[5m])) by (le, endpoint))",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },

    {
      "id": 14,
      "type": "timeseries",
      "title": "CPU Usage %",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 48 },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) by (instance) * 100)",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },

    {
      "id": 15,
      "type": "timeseries",
      "title": "Memory Usage %",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 48 },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },

    {
      "id": 16,
      "type": "timeseries",
      "title": "Disk Usage %",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 48 },
      "targets": [
        {
          "expr": "100 * ((node_filesystem_size_bytes - node_filesystem_avail_bytes) / node_filesystem_size_bytes)",
          "legendFormat": "{{mountpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    }
  ]
}